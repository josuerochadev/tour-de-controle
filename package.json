{
  "name": "tour-de-controle",
  "private": true,
  "description": "Monorepo — pre-commit hooks pour backend + frontend",
  "version": "1.3.0",
  "scripts": {
    "prepare": "husky",
    "dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d",
    "dev:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down",
    "prod": "docker compose up -d",
    "prod:down": "docker compose down",
    "test:backend": "cd backend && npm test",
    "test:frontend": "cd frontend && npm test",
    "test:all": "cd backend && npm test && cd ../frontend && npm test",
    "lint:all": "cd backend && npx biome check && cd ../frontend && npx eslint .",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui"
  },
  "lint-staged": {
    "backend/src/**/*.ts": [
      "bash -c 'cd backend && npx biome check \"$@\"' --"
    ],
    "frontend/src/**/*.{ts,tsx}": [
      "bash -c 'cd frontend && npx eslint \"$@\"' --"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.3"
  },
  "license": "MIT"
}
