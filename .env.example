# PostgreSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me
POSTGRES_DB=tour_de_controle
DB_USER=admin
DB_HOST=localhost
DB_NAME=tour_de_controle
DB_PASS=change_me
DB_PORT=5432

# Sqitch
SQITCH_USER=admin
SQITCH_PASSWORD=change_me
SQITCH_DB=tour_de_controle

# Backend
PORT=4000
JWT_SECRET=generate_a_strong_secret_here
NODE_ENV=development

# Frontend URLs
VITE_API_BASE_URL=http://localhost:4000/api
CLIENT_URL=http://localhost:5173

# SMTP (for password reset emails)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Tour de Contrôle" <noreply@tourdecontrole.app>

# Redis (for token blacklist)
REDIS_URL=redis://localhost:6379

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@tour.com
PGADMIN_DEFAULT_PASSWORD=change_me
