# ──────────────────────────────────────────────
# PostgreSQL — base de donnees principale
# ──────────────────────────────────────────────
POSTGRES_USER=admin                # Utilisateur Docker pour le conteneur PostgreSQL
POSTGRES_PASSWORD=change_me        # Mot de passe Docker pour le conteneur PostgreSQL
POSTGRES_DB=tour_de_controle       # Nom de la base creee au demarrage du conteneur

DB_USER=admin                      # Utilisateur utilise par le backend pour se connecter
DB_HOST=localhost                  # Hote PostgreSQL (localhost en dev, "db" en Docker)
DB_NAME=tour_de_controle           # Nom de la base de donnees
DB_PASS=change_me                  # Mot de passe de connexion backend
DB_PORT=5432                       # Port PostgreSQL (defaut: 5432)

# ──────────────────────────────────────────────
# Sqitch — outil de migration SQL
# ──────────────────────────────────────────────
SQITCH_USER=admin                  # Utilisateur pour les migrations Sqitch
SQITCH_PASSWORD=change_me          # Mot de passe pour les migrations Sqitch
SQITCH_DB=tour_de_controle         # Base cible des migrations

# ──────────────────────────────────────────────
# Backend Express
# ──────────────────────────────────────────────
PORT=4000                          # Port du serveur backend
JWT_SECRET=generate_a_strong_secret_here  # Secret pour signer les JWT — utiliser min 32 chars aleatoires
NODE_ENV=development               # Environnement (development | production)

# ──────────────────────────────────────────────
# URLs — communication frontend <-> backend
# ──────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:4000/api  # URL de l'API utilisee par le frontend (prefixe VITE_ requis)
CLIENT_URL=http://localhost:5173             # URL du frontend pour le CORS et les liens email

# ──────────────────────────────────────────────
# SMTP — envoi d'emails (reset password)
# Sans configuration, le reset password ne fonctionnera pas.
# En dev, utiliser https://ethereal.email pour un compte de test.
# ──────────────────────────────────────────────
SMTP_HOST=smtp.ethereal.email      # Serveur SMTP
SMTP_PORT=587                      # Port SMTP (587 = STARTTLS, 465 = SSL)
SMTP_USER=                         # Identifiant SMTP (laisser vide = emails desactives)
SMTP_PASS=                         # Mot de passe SMTP
SMTP_FROM="Tour de Contrôle" <noreply@tourdecontrole.app>  # Adresse expediteur

# ──────────────────────────────────────────────
# Redis — blacklist des tokens JWT au logout
# Optionnel : si Redis n'est pas disponible, le backend utilise un fallback en memoire
# (non persistant, perdu au redemarrage, ne scale pas sur plusieurs instances).
# ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379   # URL de connexion Redis

# ──────────────────────────────────────────────
# pgAdmin — interface web d'administration PostgreSQL (Docker uniquement)
# ──────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@tour.com       # Email de connexion pgAdmin
PGADMIN_DEFAULT_PASSWORD=change_me         # Mot de passe pgAdmin
