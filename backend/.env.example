# Backend Express — variables requises pour lancer le serveur
# Copier ce fichier vers .env a la racine du projet (ou dans backend/)

DB_USER=admin                      # PostgreSQL user
DB_HOST=localhost                  # PostgreSQL host (localhost en dev, "db" en Docker)
DB_NAME=tour_de_controle           # PostgreSQL database name
DB_PASS=change_me                  # PostgreSQL password
DB_PORT=5432                       # PostgreSQL port

PORT=4000                          # Express server port
JWT_SECRET=generate_a_strong_secret_here  # REQUIRED — server will crash without this variable
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
NODE_ENV=development               # development | production | test

CLIENT_URL=http://localhost:5173   # Frontend URL (CORS origin)

# SMTP — required for password reset emails
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Tour de Contrôle" <noreply@tourdecontrole.app>

# Redis — optional, in-memory fallback if unavailable
REDIS_URL=redis://localhost:6379
