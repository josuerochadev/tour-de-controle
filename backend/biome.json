{
	"$schema": "https://json.schemastore.org/schema-catalog.json",
	"files": {
		"ignore": ["dist/**", "node_modules/**"]
	},
	"formatter": {
		"lineWidth": 80,
		"indentStyle": "space",
		"indentWidth": 2
	},
	"linter": {
		"rules": {
			"recommended": true,
			"complexity": {
				"noExtraBooleanCast": "error",
				"noUselessSwitchCase": "error"
			},
			"correctness": {
				"noUnusedVariables": "warn",
				"noUnusedImports": "warn"
			},
			"suspicious": {
				"noExplicitAny": "warn",
				"noDoubleEquals": "error"
			},
			"style": {
				"useConst": "error",
				"noVar": "error"
			}
		}
	}
}
